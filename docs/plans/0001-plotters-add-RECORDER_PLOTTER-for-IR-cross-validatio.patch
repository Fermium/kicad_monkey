+
+// =============================================================================
+// Lifecycle
+// =============================================================================
+
+
+bool RECORDER_PLOTTER::StartPlot( const wxString& aPageNumber )
+{
+    ordered_json payload = {
+        { "page_number", aPageNumber.utf8_string() }
+    };
+    m_ops.push_back( { { "kind", "StartPlot" }, { "payload", std::move( payload ) } } );
+    return true;
+}
+
+
+bool RECORDER_PLOTTER::EndPlot()
+{
+    m_ops.push_back( { { "kind", "EndPlot" }, { "payload", ordered_json::object() } } );
+
+    if( !m_outputFile )
+        return false;
+
+    ordered_json doc = {
+        { "schema",  SCHEMA_ID },
+        { "canvas",  m_canvas },
+        { "ops",     m_ops }
+    };
+
+    const std::string serialised = doc.dump( 2 );
+    std::fputs( serialised.c_str(), m_outputFile );
+    std::fputc( '\n', m_outputFile );
+    std::fflush( m_outputFile );
+    return true;
+}
