+// =============================================================================
+// Construction
+// =============================================================================
+
+
+RECORDER_PLOTTER::RECORDER_PLOTTER() :
+        PLOTTER(),
+        m_ops( ordered_json::array() ),
+        m_canvas( ordered_json::object() )
+{
+}
+
+
+RECORDER_PLOTTER::~RECORDER_PLOTTER()
+{
+}
