+// =============================================================================
+// Local helpers
+// =============================================================================
+
+
+namespace
+{
+
+const char* fillName( FILL_T aFill )
+{
+    switch( aFill )
+    {
+    case FILL_T::NO_FILL:                  return "NO_FILL";
+    case FILL_T::FILLED_SHAPE:             return "FILLED_SHAPE";
+    case FILL_T::FILLED_WITH_BG_BODYCOLOR: return "FILLED_WITH_BG_BODYCOLOR";
+    case FILL_T::FILLED_WITH_COLOR:        return "FILLED_WITH_COLOR";
+    case FILL_T::HATCH:                    return "HATCH";
+    case FILL_T::REVERSE_HATCH:            return "REVERSE_HATCH";
+    case FILL_T::CROSS_HATCH:              return "CROSS_HATCH";
+    }
+    return "NO_FILL";
+}
+
+
+const char* lineStyleName( LINE_STYLE aStyle )
+{
+    switch( aStyle )
+    {
+    case LINE_STYLE::DEFAULT:    return "DEFAULT";
+    case LINE_STYLE::SOLID:      return "SOLID";
+    case LINE_STYLE::DASH:       return "DASH";
+    case LINE_STYLE::DOT:        return "DOT";
+    case LINE_STYLE::DASHDOT:    return "DASHDOT";
+    case LINE_STYLE::DASHDOTDOT: return "DASHDOTDOT";
+    }
+    return "SOLID";
+}
+
+
+const char* hAlignName( GR_TEXT_H_ALIGN_T aAlign )
+{
+    switch( aAlign )
+    {
+    case GR_TEXT_H_ALIGN_LEFT:          return "GR_TEXT_H_ALIGN_LEFT";
+    case GR_TEXT_H_ALIGN_CENTER:        return "GR_TEXT_H_ALIGN_CENTER";
+    case GR_TEXT_H_ALIGN_RIGHT:         return "GR_TEXT_H_ALIGN_RIGHT";
+    case GR_TEXT_H_ALIGN_INDETERMINATE: return "GR_TEXT_H_ALIGN_INDETERMINATE";
+    }
+    return "GR_TEXT_H_ALIGN_LEFT";
+}
+
+
+const char* vAlignName( GR_TEXT_V_ALIGN_T aAlign )
+{
+    switch( aAlign )
+    {
+    case GR_TEXT_V_ALIGN_TOP:           return "GR_TEXT_V_ALIGN_TOP";
+    case GR_TEXT_V_ALIGN_CENTER:        return "GR_TEXT_V_ALIGN_CENTER";
+    case GR_TEXT_V_ALIGN_BOTTOM:        return "GR_TEXT_V_ALIGN_BOTTOM";
+    case GR_TEXT_V_ALIGN_INDETERMINATE: return "GR_TEXT_V_ALIGN_INDETERMINATE";
+    }
+    return "GR_TEXT_V_ALIGN_BOTTOM";
+}
+
+
+std::string colorToHex( const COLOR4D& aColor )
+{
+    auto clamp = []( double v ) -> int
+    {
+        if( v < 0.0 ) v = 0.0;
+        if( v > 1.0 ) v = 1.0;
+        return static_cast<int>( v * 255.0 + 0.5 );
+    };
+
+    char buf[10];
+    std::snprintf( buf, sizeof( buf ), "#%02X%02X%02X%02X",
+                   clamp( aColor.r ),
+                   clamp( aColor.g ),
+                   clamp( aColor.b ),
+                   clamp( aColor.a ) );
+    return std::string( buf );
+}
+
+
+ordered_json pointArray( const std::vector<VECTOR2I>& aPoints )
+{
+    ordered_json arr = ordered_json::array();
+    for( const VECTOR2I& p : aPoints )
+        arr.push_back( { p.x, p.y } );
+    return arr;
+}
+
