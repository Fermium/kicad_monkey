+void RECORDER_PLOTTER::FlashPadTrapez( const VECTOR2I& aPadPos, const VECTOR2I* aCorners,
+                                       const EDA_ANGLE& aPadOrient, void* /*aData*/ )
+{
+    ordered_json corners = ordered_json::array();
+    if( aCorners )
+    {
+        for( int i = 0; i < 4; ++i )
+            corners.push_back( { aCorners[i].x, aCorners[i].y } );
+    }
+
+    m_ops.push_back( {
+        { "kind",    "FlashPadTrapez" },
+        { "payload", {
+            { "x",          aPadPos.x },
+            { "y",          aPadPos.y },
+            { "corners",    std::move( corners ) },
+            { "orient_deg", aPadOrient.AsDegrees() }
+        } }
+    } );
+}
