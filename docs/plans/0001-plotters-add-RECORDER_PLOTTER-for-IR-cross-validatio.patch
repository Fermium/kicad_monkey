+void RECORDER_PLOTTER::SetViewport( const VECTOR2I& aOffset, double aIusPerDecimil,
+                                    double aScale, bool aMirror )
+{
+    m_plotOffset       = aOffset;
+    m_plotScale        = aScale;
+    m_IUsPerDecimil    = aIusPerDecimil;
+    m_iuPerDeviceUnit  = 1.0 / aIusPerDecimil;
+    m_plotMirror       = aMirror;
+
+    m_ops.push_back( {
+        { "kind",    "SetViewport" },
+        { "payload", {
+            { "offset_x_nm",      aOffset.x },
+            { "offset_y_nm",      aOffset.y },
+            { "ius_per_decimil",  aIusPerDecimil },
+            { "scale",            aScale },
+            { "mirror",           aMirror }
+        } }
+    } );
+}
+
+
+void RECORDER_PLOTTER::SetPageSettings( const PAGE_INFO& aPageSettings )
+{
+    PLOTTER::SetPageSettings( aPageSettings );
+
+    // Cache canvas dims for the document envelope (mils → nm at 25400 nm/mil).
+    const long long width_nm  =
+            static_cast<long long>( aPageSettings.GetWidthMils() * 25400.0 + 0.5 );
+    const long long height_nm =
+            static_cast<long long>( aPageSettings.GetHeightMils() * 25400.0 + 0.5 );
+
+    m_canvas = {
+        { "type",      aPageSettings.GetTypeAsString().utf8_string() },
+        { "width_nm",  width_nm },
+        { "height_nm", height_nm },
+        { "portrait",  aPageSettings.IsPortrait() }
+    };
+
+    m_ops.push_back( {
+        { "kind",    "SetPageSettings" },
+        { "payload", m_canvas }
+    } );
+}
+
