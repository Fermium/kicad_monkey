From d39cce95f59430d9095f873dca160802c2bfb967 Mon Sep 17 00:00:00 2001
From: Eli Hughes <ehughes@wavenumber.net>
Date: Sat, 9 May 2026 17:14:50 -0400
Subject: [PATCH 2/3] eeschema: env-var hook to plug RECORDER_PLOTTER into SVG
 export

Adds a minimal diagnostic seam in SCH_PLOTTER::plotOneSheetSVG: when
the env var KICAD_RECORDER_OUTPUT is set the SVG plot path is replaced
with a RECORDER_PLOTTER instance, and output is written to
"<KICAD_RECORDER_OUTPUT>.<page-number>.json" instead of the usual SVG
path. Default behavior is unchanged when the env var is unset.

This enables cross-validating external tools (e.g. kicad_monkey's
schematic_to_ir / render_ir_to_svg pipeline) against the canonical
KiCad plot stream by capturing every PLOTTER virtual call as JSON.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 eeschema/sch_plotter.cpp | 31 ++++++++++++++++++++++++++++---
 1 file changed, 28 insertions(+), 3 deletions(-)

diff --git a/eeschema/sch_plotter.cpp b/eeschema/sch_plotter.cpp
index 85b073c145..4e801f38b2 100644
--- a/eeschema/sch_plotter.cpp
+++ b/eeschema/sch_plotter.cpp
@@ -29,6 +29,7 @@
 #include <sch_plotter.h>
 #include <plotters/plotter_dxf.h>
 #include <plotters/plotter_png.h>
+#include <plotters/plotter_recorder.h>
 #include <plotters/plotters_pslike.h>
 
 #include <pgm_base.h>
@@ -615,7 +616,31 @@ bool SCH_PLOTTER::plotOneSheetSVG( const wxString& aFileName, SCH_SCREEN* aScree
         break;
     }
 
-    SVG_PLOTTER* plotter = new SVG_PLOTTER();
+    // Diagnostic hook (Phase F-6 RECORDER_PLOTTER): when KICAD_RECORDER_OUTPUT
+    // is set the SVG export path is replaced with a JSON dump of every
+    // PLOTTER virtual call. Used to cross-validate external tooling against
+    // the canonical KiCad plot pipeline. Output goes to
+    // "<KICAD_RECORDER_OUTPUT>.<page-number>.json" so multi-page schematics
+    // do not collide.
+    const char* recorderEnv = std::getenv( "KICAD_RECORDER_OUTPUT" );
+    const bool  recordMode  = recorderEnv && *recorderEnv;
+
+    PLOTTER* plotter = nullptr;
+    wxString outputPath;
+
+    if( recordMode )
+    {
+        plotter = new RECORDER_PLOTTER();
+        outputPath = wxString::Format( wxT( "%s.%s.json" ),
+                                       wxString::FromUTF8( recorderEnv ),
+                                       m_schematic->CurrentSheet().GetPageNumber() );
+    }
+    else
+    {
+        plotter = new SVG_PLOTTER();
+        outputPath = aFileName;
+    }
+
     plotter->SetRenderSettings( aRenderSettings );
     plotter->SetPageSettings( plotPage );
     plotter->SetColorMode( aPlotOpts.m_blackAndWhite ? false : true );
@@ -629,9 +654,9 @@ bool SCH_PLOTTER::plotOneSheetSVG( const wxString& aFileName, SCH_SCREEN* aScree
     plotter->SetViewport( plot_offset, schIUScale.IU_PER_MILS / 10, scale, false );
 
     // Init :
-    plotter->SetCreator( wxT( "Eeschema-SVG" ) );
+    plotter->SetCreator( recordMode ? wxT( "Eeschema-RECORDER" ) : wxT( "Eeschema-SVG" ) );
 
-    if( !plotter->OpenFile( aFileName ) )
+    if( !plotter->OpenFile( outputPath ) )
     {
         delete plotter;
         return false;
